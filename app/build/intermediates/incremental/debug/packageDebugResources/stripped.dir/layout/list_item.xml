<?xml version="1.0" encoding="utf-8"?>
<mtkdex.core.build.ssmen.view.swipe.ListSwipeItem
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:swipeViewId="@+id/item_layout"
    android:gravity="center">

    <!-- Card for Shadow and Rounded Corners -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item_layout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/black_light">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Drag Handle -->
                <ImageView
                    android:id="@+id/dragHandle"
                    android:layout_width="11dp"
                    android:layout_height="14dp"
                    android:src="@drawable/menu_burger"
                    app:tint="#B0B0B0"
                    android:layout_marginLeft="8dp"/>

                <!-- 3D Icon Container -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/image"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="100dp"
                    android:layout_marginLeft="5dp">

                    <ImageView
                        android:id="@+id/icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerInParent="true"
                        android:src="@drawable/icon_icon" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/round_3d_circle">
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Text Content -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/name1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Server Name"
                        android:fontFamily="@font/google_sans_flex"
                        android:textColor="@color/colorText"
                        android:textSize="11sp"
                        app:fontVariationSettings="'wght' 500"/>

                    <TextView
                        android:id="@+id/name2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Description text"
                        android:textColor="@color/colorPrimary"
                        android:textSize="10sp"
                        android:fontFamily="@font/google_sans_flex"
                        app:fontVariationSettings="'wght' 500"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Triangle Badge and Text -->
            <FrameLayout
                android:layout_width="70dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:clipChildren="false">

                <!-- The Triangle Background -->
                <View
                    android:id="@+id/name3_ly"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/badge_triangle" />

                <!--
                   Container focused on the top-right corner.
                   By making this container smaller (e.g., 60dp) and centering the text,
                   it stays perfectly on the diagonal.
                -->
                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:rotation="45"
                    android:layout_marginTop="3dp"
                    android:layout_marginEnd="-18dp">

                    <TextView
                        android:id="@+id/name3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Premium"
                        android:textColor="@android:color/white"
                        android:fontFamily="@font/google_sans_flex"
                        app:fontVariationSettings="'wght' 400"
                        android:textSize="6sp"
                        android:gravity="center"
                        android:maxLines="1"/>
                </FrameLayout>
            </FrameLayout>

            <!-- Hidden Menu -->
            <ImageView
                android:id="@+id/image_menu"
                android:layout_width="25dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:padding="2dp"
                android:visibility="gone"
                app:tint="@color/grey_500"
                android:src="@drawable/ic_cg" />

        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

</mtkdex.core.build.ssmen.view.swipe.ListSwipeItem>
