<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:background="@color/transparent">

    <LinearLayout
        android:id="@+id/log_bottom_sheet"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:background="@color/transparent"
        android:orientation="vertical"
        app:behavior_hideable="false"
        app:behavior_peekHeight="50dp"
        app:behavior_fitToContents="true"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Top Border Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorTextSecondary" />

        <!-- Status Bar -->
        <LinearLayout
            android:id="@+id/log_view"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="15dp"
            android:paddingEnd="15dp">

            <ImageView
                android:id="@+id/show_log_view"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginEnd="15dp"
                app:srcCompat="@drawable/ic_hide_set"
                app:tint="@color/black_light" />

            <TextView
                android:id="@+id/log_connection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="STATUS: Disconnected"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12.5sp"
                app:fontVariationSettings="'wght' 520"
                android:fontFamily="@font/google_sans_flex"
                android:letterSpacing="0.05" />

            <ImageView
                android:id="@+id/status_log_menu"
                android:layout_width="18dp"
                android:layout_height="18dp"
                app:srcCompat="@drawable/three_dot_menu"
                app:tint="@color/black_light" />

        </LinearLayout>

        <!-- Log List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:visibility="visible" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>