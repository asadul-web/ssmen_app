<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:gravity="center|top"
    android:background="#FFFFFF">

    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:alpha="0.1"
        android:scaleType="centerCrop"
        app:lottie_autoPlay="true"
        app:lottie_fileName="animationlogin_bg.json"
        app:lottie_loop="true"
        android:visibility="gone"/>

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/main_toolbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="vertical"
        android:gravity="center|top"
        android:background="@color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:orientation="horizontal"
            android:gravity="center">

            <RelativeLayout
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:gravity="start|center">

                <ImageView
                    android:id="@+id/mDrawerMenu"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:src="@drawable/bq5"
                    app:tint="@color/colorText"/>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginTop="5dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="FIGHTER"
                        android:textColor="@color/colorPrimary"
                        android:textSize="17sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="-V2Ray"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="serif"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Internet. Your Rules"
                    android:textSize="10sp"
                    android:textColor="@color/grey_500"
                    android:gravity="center|top"
                    android:layout_marginStart="5dp"
                    android:fontFamily="@font/google_sans_flex" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="35dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="4dp">

            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content ScrollView -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/main_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/main_toolbar"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="50dp"
        android:gravity="center"
        android:orientation="vertical">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center|top">

            <View
                android:id="@+id/graph_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- Download/Upload Tracker - Vertical Stacked Design -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginRight="25dp"
                android:layout_marginLeft="25dp"
                android:gravity="center">

                <mtkdex.core.build.ssmen.view.TrafficGraphView
                    android:id="@+id/trafficGraph"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    app:inColor="#00E977"
                    app:outColor="#FF1744"
                    app:lineWidth="1dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="-6dp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/config_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_weight="1"
                        android:gravity="start"
                        android:text="Config 1.71"
                        android:textSize="8sp"
                        android:fontFamily="@font/google_sans_flex" />

<!--                    <TextView-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_gravity="center"-->
<!--                        android:layout_weight="1"-->
<!--                        android:gravity="center"-->
<!--                        android:text="◦"-->
<!--                        android:textSize="8sp" />-->

                    <TextView
                        android:id="@+id/graph_ip_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="10.155.209.91"
                        android:textSize="8sp"
                        android:fontFamily="@font/google_sans_flex" />

<!--                    <TextView-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_gravity="center"-->
<!--                        android:layout_weight="1"-->
<!--                        android:gravity="center"-->
<!--                        android:text="◦"-->
<!--                        android:textSize="8sp" />-->

                    <TextView
                        android:id="@+id/graph_net_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:singleLine="true"
                        android:text="Wifi connection"
                        android:textSize="8sp"
                        android:fontFamily="@font/google_sans_flex" />

                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connection Time"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/google_sans_flex" />

                <TextView
                    android:id="@+id/duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="00h:00m:00s"
                    android:textColor="@color/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/google_sans_flex" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginStart="8.5dp"
                android:layout_marginEnd="8.5dp">

                <!-- Download -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="left"
                    android:layout_marginRight="0dp">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic11"
                        android:tint="#4CAF50"
                        android:layout_marginRight="5dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download"
                            android:textColor="@color/black_light"
                            android:textSize="9sp"
                            android:layout_marginLeft="2dp"
                            android:layout_marginRight="2dp"
                            android:fontFamily="@font/google_sans_flex" />

                        <TextView
                            android:id="@+id/bytes_in"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B"
                            android:textColor="@color/black_light"
                            android:textSize="8sp"
                            android:fontFamily="@font/google_sans_flex"
                            android:textStyle="bold"
                            android:layout_marginLeft="2dp"
                            android:layout_marginRight="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Protocol (Center) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_shield"
                        android:tint="@color/colorAccent"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tunnel_spin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="V2Ray"
                        android:textColor="@color/black_light"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/google_sans_flex"
                         />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protocol"
                        android:textColor="@color/black_light"
                        android:textSize="8sp"
                        android:fontFamily="@font/google_sans_flex" />
                </LinearLayout>

                <!-- Upload -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginLeft="65dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload"
                            android:textColor="@color/black_light"
                            android:textSize="9sp"
                            android:layout_marginLeft="2dp"
                            android:layout_marginRight="2dp"
                            android:fontFamily="@font/google_sans_flex" />

                        <TextView
                            android:id="@+id/bytes_out"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B"
                            android:textColor="@color/black_light"
                            android:textSize="8sp"
                            android:fontFamily="@font/google_sans_flex"
                            android:textStyle="bold"
                            android:layout_marginLeft="2dp"
                            android:layout_marginRight="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic12"
                        android:tint="#FF5722"
                        android:layout_marginLeft="5dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Server Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_marginStart="8.5dp"
                android:layout_marginEnd="8.5dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0.5dp"
                app:cardBackgroundColor="@color/colorPrimary">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:gravity="center">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="start|center"
                        android:background="@drawable/bg_box_card_rounded_light"
                        android:layout_margin="1dp">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="start|center"
                            android:layout_marginStart="1dp">

                            <LinearLayout
                                android:id="@+id/server_spinner"
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClick="onClick">

                                <RelativeLayout
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:background="@color/transparent">

                                    <ImageView
                                        android:id="@+id/server_spin_icon"
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:padding="1dp"
                                        android:src="@drawable/app_main_logo"/>
                                </RelativeLayout>

                                <LinearLayout
                                    android:orientation="vertical"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1">

                                    <TextView
                                        android:id="@+id/server_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="Server"
                                        android:textSize="12dp"
                                        android:textStyle="bold"
                                        android:textColor="@color/black"
                                        android:singleLine="true"
                                        android:paddingStart="7dp"
                                        android:fontFamily="@font/google_sans_flex" />

                                    <TextView
                                        android:id="@+id/server_info"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="High Speed"
                                        android:textSize="9sp"
                                        android:singleLine="true"
                                        android:paddingStart="7dp"
                                        android:fontFamily="@font/google_sans_flex" />
                                </LinearLayout>

                                <RelativeLayout
                                    android:id="@+id/v2ray_ping_ly"
                                    android:layout_width="60dp"
                                    android:layout_height="20dp"
                                    android:gravity="center"
                                    android:visibility="visible"
                                    android:layout_marginStart="5dp">

                                    <TextView
                                        android:id="@+id/v2ray_ping"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="~ ms"
                                        android:textColor="@color/grey_500"
                                        android:gravity="center"
                                        android:background="@color/transparent"
                                        android:layout_centerInParent="true"
                                        android:fontFamily="@font/google_sans_flex" />
                                </RelativeLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Network Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="8.5dp"
                android:layout_marginEnd="8.5dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0.5dp"
                app:cardBackgroundColor="@color/colorPrimary">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:gravity="center">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center|left"
                        android:background="@drawable/bg_box_card_rounded_light"
                        android:layout_margin="1dp">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="start|center"
                            android:layout_marginStart="1dp">

                            <LinearLayout
                                android:id="@+id/payload_spinner"
                                android:orientation="horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClick="onClick">

                                <mtkdex.core.build.ssmen.view.RoundCornerLayout
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    app:bottomLeftEnabled="true"
                                    app:bottomRightEnabled="true"
                                    app:cornerRadius="100dp"
                                    app:topLeftEnabled="true"
                                    app:topRightEnabled="true">

                                    <RelativeLayout
                                        android:layout_width="30dp"
                                        android:layout_height="30dp">

                                        <ImageView
                                            android:id="@+id/payload_spin_icon"
                                            android:layout_width="30dp"
                                            android:layout_height="30dp"
                                            android:layout_gravity="center"
                                            android:src="@drawable/app_main_logo"/>
                                    </RelativeLayout>
                                </mtkdex.core.build.ssmen.view.RoundCornerLayout>

                                <LinearLayout
                                    android:orientation="vertical"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1">

                                    <TextView
                                        android:id="@+id/payload_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="Payload"
                                        android:textSize="12dp"
                                        android:textStyle="bold"
                                        android:textColor="@color/black"
                                        android:singleLine="true"
                                        android:layout_marginStart="7dp"
                                        android:fontFamily="@font/google_sans_flex" />

                                    <TextView
                                        android:id="@+id/payload_info"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:text="High Speed"
                                        android:textSize="9dp"
                                        android:singleLine="true"
                                        android:layout_marginStart="7dp"
                                        android:fontFamily="@font/google_sans_flex" />
                                </LinearLayout>

                                <RelativeLayout
                                    android:id="@+id/network_tag_ly"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:background="@drawable/fix_tag_frame"
                                    android:padding="1dp">

                                    <TextView
                                        android:id="@+id/payload_tag_text"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="V2ray/Xray"
                                        android:textSize="9sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/white"
                                        android:gravity="center"
                                        android:paddingLeft="3dp"
                                        android:paddingRight="3dp"
                                        android:singleLine="true"
                                        android:fontFamily="@font/google_sans_flex" />
                                </RelativeLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Connection Info Footer -->

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="5dp">

                <mtkdex.core.build.ssmen.view.RotateLoading
                    android:id="@+id/mRotateLoading"
                    android:layout_width="144dp"
                    android:layout_height="144dp"
                    android:layout_centerInParent="true"
                    app:loading_color="#14B455"
                    app:loading_visible="false"
                    app:loading_width="7dp" />

                <mtkdex.core.build.ssmen.view.CircleProgressBar
                    android:id="@+id/circle_progress"
                    android:layout_width="125dp"
                    android:layout_height="125dp"
                    android:layout_centerInParent="true"
                    app:progress="0"
                    app:progressBarThickness="10dp" />

                <View
                    android:id="@+id/btn_ly"
                    android:layout_width="106dp"
                    android:layout_height="106dp"
                    android:layout_centerInParent="true"
                    android:background="@drawable/bg_btn_card_white" />

                <RelativeLayout
                    android:id="@+id/btn_card_frame"
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    android:layout_centerInParent="true">

                    <ImageView
                        android:id="@+id/btn_connect_icon"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_centerHorizontal="true"
                        android:layout_centerVertical="true"
                        android:layout_marginTop="25dp"
                        android:src="@drawable/logout_button"
                        app:tint="@color/colorPrimary" />

                    <Button
                        android:id="@+id/btn_connect"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:onClick="onClick" />
                </RelativeLayout>
            </RelativeLayout>

            <!-- Account Expiry -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:layout_marginTop="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Expiration Details"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:textColor="@color/grey_700"
                    android:visibility="visible"
                    android:fontFamily="@font/google_sans_flex" />

                <TextView
                    android:id="@+id/ac_xp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expires: January 22, 2026 | 28 Days"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="5dp"
                    android:maxLines="1"
                    android:fontFamily="@font/google_sans_flex" />
            </LinearLayout>

            <!-- Hidden Elements for MainActivity compatibility -->
            <TextView
                android:id="@+id/status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/sname1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/pname1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/sSpin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/pSpin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/mDataInTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans_flex"
                android:visibility="gone" />

            <TextView
                android:id="@+id/mDataOutTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans_flex"
                android:visibility="gone" />

            <TextView
                android:id="@+id/val1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans_flex"
                android:visibility="gone" />

            <TextView
                android:id="@+id/val2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans_flex"
                android:visibility="gone" />

            <TextView
                android:id="@+id/livedata"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/google_sans_flex"
                android:visibility="gone" />

            <TextView
                android:id="@+id/main_tl1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/show_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ac_user_box_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <EditText
                android:id="@+id/x_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <EditText
                android:id="@+id/x_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <Spinner
                android:id="@+id/portSpin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/prxSpin"
                android:layout_width="wrap_content"
