<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_adapt_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Blue Header -->
        <RelativeLayout
            android:id="@+id/config_bord_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_rounded"
            android:paddingHorizontal="25dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Bordered Search Box Container -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/border_transparent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_container"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="15dp">

                <EditText
                    android:id="@+id/config_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="start|center_vertical"
                    android:hint="Search here"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:fontFamily="@font/google_sans_flex"
                    android:textColor="@color/colorText"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/clear_btn"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:padding="3dp"
                    android:src="@drawable/ic_close"
                    android:visibility="visible"
                    app:tint="@color/black_light" />

                <ImageView
                    android:id="@+id/search_btn"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:padding="2dp"
                    android:layout_marginRight="15dp"
                    android:src="?android:attr/actionModeWebSearchDrawable"
                    android:visibility="visible"
                    app:tint="@color/black_light" />
            </LinearLayout>
            </LinearLayout>

        </RelativeLayout>

        <!-- White Content Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white"
            android:orientation="vertical">

            <!-- Tab Switching Buttons (Network/Custom) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tab_container"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="7dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="0.8dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_tab_outline"
                    android:orientation="horizontal">

                <TextView
                    android:id="@+id/tab_all"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_selected"
                    android:gravity="center"
                    android:text="All Networks List"
                    android:fontFamily="@font/google_sans_flex"
                    app:fontVariationSettings="'wght' 300"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_custom"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Custom List"
                    android:textColor="@color/colorPrimary"
                    android:fontFamily="@font/google_sans_flex"
                    app:fontVariationSettings="'wght' 300"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Auto Select Row (Reverted to original design) -->
            <LinearLayout
                android:id="@+id/show_random_l"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginHorizontal="9dp"
                android:layout_marginTop="7dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/border_item_normal"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginLeft="12dp"
                    app:srcCompat="@drawable/ic_hide_set"
                    app:tint="@color/black_light" />

                <mtkdex.core.build.ssmen.view.RoundCornerLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="8dp"
                    app:cornerRadius="100dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#F5F5F5">
                        <ImageView
                            android:id="@+id/icon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:src="@drawable/auto_sel_server" />
                    </RelativeLayout>
                </mtkdex.core.build.ssmen.view.RoundCornerLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/use_random1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto select servers"
                        android:fontFamily="@font/google_sans_flex"
                        android:textColor="@color/colorText"
                        android:textSize="10sp"
                        app:fontVariationSettings="'wght' 500" />
                    <TextView
                        android:id="@+id/use_random2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Random"
                        android:textColor="@color/colorPrimary"
                        android:textSize="9sp"
                        android:fontFamily="@font/google_sans_flex"
                        app:fontVariationSettings="'wght' 700"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/name3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_auto_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_marginRight="15dp"
                    android:text="AUTO"
                    android:textColor="@color/white"
                    android:textSize="6sp"
                    android:fontFamily="@font/google_sans_flex"
                    app:fontVariationSettings="'wght' 500" />
            </LinearLayout>

            <!-- Main List -->
            <mtkdex.core.build.ssmen.view.swipe.DragListView
                android:id="@+id/config_listview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="10dp"
                android:layout_marginTop="2dp"/>

            <!-- Footer -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:paddingHorizontal="15dp">

                <LinearLayout
                    android:id="@+id/config_btn_close_add"
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_create_btn"
                    android:gravity="center"
                    android:layout_marginLeft="5dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        app:cardBackgroundColor="@color/colorPrimary"
                        android:paddingHorizontal="15dp"
                        android:gravity="center"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/server_spin_icon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="5dp"
                            android:src="@drawable/input_icon" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/config_btn_add_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="CREATE"
                        android:fontFamily="@font/google_sans_flex"
                        android:textColor="@color/colorText"
                        android:textSize="10sp"
                        app:fontVariationSettings="'wght' 500" />
                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/config_btn_close"
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_close_btn"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/config_btn_closetv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLOSE"
                        android:fontFamily="@font/google_sans_flex"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        app:fontVariationSettings="'wght' 500" />
                </RelativeLayout>
            </RelativeLayout>

            <!-- Hidden Views -->
            <TextView android:id="@+id/config_title" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageView android:id="@+id/paygen_menu" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <View android:id="@+id/random_space_lay" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>