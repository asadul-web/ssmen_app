<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="ListSwipeItem">
        <attr name="swipeViewId" format="integer"/>
        <attr name="leftViewId" format="integer"/>
        <attr name="rightViewId" format="integer"/>
    </declare-styleable>
    <declare-styleable name="ShowHidePasswordEditText">
        <attr name="drawable_hide" format="integer"/>
        <attr name="drawable_show" format="integer"/>
        <attr name="tint_color" format="color"/>
        <attr name="additionalTouchTargetSize" format="dimension"/>
    </declare-styleable>
    <declare-styleable name="RoundCorner">
        <attr name="cornerRadius" format="dimension" />
        <attr name="topEnabled" format="boolean" />
        <attr name="bottomEnabled" format="boolean" />
        <attr name="topLeftEnabled" format="boolean" />
        <attr name="topRightEnabled" format="boolean" />
        <attr name="bottomLeftEnabled" format="boolean" />
        <attr name="bottomRightEnabled" format="boolean" />
    </declare-styleable>
    <declare-styleable name="SnakeView">
        <attr name="strokeColor" format="color" />
        <attr name="fillColor" format="color" />
        <attr name="strokeWidth" format="dimension" />
        <attr name="minValue" format="float" />
        <attr name="maxValue" format="float" />
        <attr name="maximumNumberOfValues" format="integer" />
        <attr name="animationDuration" format="integer" />
        <attr name="scaleMode">
            <enum name="fixed" value="0" />
            <enum name="auto" value="1" />
        </attr>
        <attr name="chartStyle">
            <enum name="stroke" value="0" />
            <enum name="fill" value="1" />
            <enum name="fill_stroke" value="2" />
        </attr>
    </declare-styleable>
    <array name="server_category">
        <item>Websocket Ovpn</item>
        <item>Fast V2ray</item>
        <item>Fast Ssh</item>
        <item>Dnstt Server</item>
        <item>Fast Udp</item>
    </array>
    <array name="server_type">
        <item>OpenVPN</item>
        <item>SSH</item>
        <item>SlowDns</item>
        <item>v2ray</item>
        <item>UDP Hysteria</item>
    </array>
    <array name="network_proto">
        <item>HTTP Proxy</item>
        <item>UDP Hysteria</item>
        <item>SlowDns</item>
        <item>V2ray/Xray</item>
    </array>
    <array name="payload_v2ray_type">
        <item>Normal Service</item>
        <item>CDN Service</item>
        <item>SSL Service</item>
    </array>
    <array name="server_v2ray_type">
        <item>Normal Service</item>
        <item>CDN Service</item>
        <item>SSL Service</item>
    </array>
    <array name="ssl_type">
        <item>SSL/SNI</item>
        <item>SSL+PAYLOAD</item>
        <item>SSL+PROXY</item>
    </array>    <declare-styleable name="DataGraph">
        <attr name="dg_colorDown" format="color" />
        <attr name="dg_colorUp" format="color" />
        <attr name="dg_colorText" format="color" />
    </declare-styleable>

    <declare-styleable name="Graph">
        <attr name="lineColor" format="color"/>
        <attr name="lineUpColor" format="color"/>
        <attr name="lineDownColor" format="color"/>
    </declare-styleable>

    <declare-styleable name="CircleProgressBar">
        <attr name="min" format="integer" />
        <attr name="max" format="integer" />
        <attr name="progress" format="integer" />
        <attr name="progressbarColor" format="color" />
        <attr name="progressBarThickness" format="dimension" />
    </declare-styleable>

    <declare-styleable name="RotateLoading">
        <attr name="loading_width" format="dimension"/>
        <attr name="loading_color" format="color"/>
        <attr name="shadow_offset" format="dimension"/>
        <attr name="loading_visible" format="boolean"/>
    </declare-styleable>

    <declare-styleable name="TrafficGraphView">
        <attr name="inColor" format="color" />
        <attr name="outColor" format="color" />
        <attr name="lineWidth" format="dimension" />
    </declare-styleable>

</resources>
