<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/main_toolbar"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@color/white"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="5dp">

        <ImageView
            android:id="@+id/mDrawerMenu"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="5dp"
            android:clickable="true"
            android:focusable="true"
            app:srcCompat="@drawable/menu" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="FIGHTER"
                    android:textColor="@color/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/google_sans_flex"
                    android:text="-"
                    android:textColor="@color/black_light"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="V2Ray"
                    android:textColor="@color/black_light"
                    android:textSize="17sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-3dp"
                android:fontFamily="@font/google_sans_flex"
                app:fontVariationSettings="'wght' 300"
                android:letterSpacing="0.05"
                android:text="lightening and multiverse xm"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:srcCompat="@drawable/three_dot_menu" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/main_toolbar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="80dp">

            <View
                android:id="@+id/graph_layout"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="40dp"
                android:orientation="vertical"
                android:gravity="center">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginTop="5dp">

                    <mtkdex.core.build.ssmen.view.TrafficGraphView
                        android:id="@+id/trafficGraph"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_above="@+id/graph_info_layout"
                        android:layout_alignParentTop="true"
                        app:inColor="@color/dataIn"
                        app:lineWidth="1.5dp"
                        app:outColor="@color/dataOut" />

                    <LinearLayout
                        android:id="@+id/graph_labels_layout"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="5dp"
                        android:gravity="end"
                        android:orientation="vertical"
                        android:paddingEnd="5dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/mDataInTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/google_sans_flex"
                            android:text="0 bit"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/mDataOutTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/google_sans_flex"
                            android:text="0 bit"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/val1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/google_sans_flex"
                            android:text="0 bit"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/val2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/google_sans_flex"
                            android:text="0 bit"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/livedata_layout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBottom="@+id/trafficGraph"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="43.8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/livedata"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/google_sans_flex"
                            android:text="LiveData"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="7sp" />

                        <View
                            android:id="@+id/livedata_dot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="3dp"
                            android:layout_marginBottom="-0.5dp"
                            android:background="@drawable/livedata_dot_red" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/graph_info_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginLeft="0dp"
                        android:layout_marginRight="10dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <TextView
                            android:id="@+id/config_version"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/google_sans_flex"
                            android:gravity="start"
                            android:text="Config: 13.8"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/graph_ip_address"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/google_sans_flex"
                            android:gravity="center"
                            android:text="192.168.0.5"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/graph_net_type"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/google_sans_flex"
                            android:gravity="end"
                            android:paddingRight="4dp"
                            android:text="Wifi connection"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="8sp" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/google_sans_flex"
                        app:fontVariationSettings="'wght' 550"
                        android:text="Connection Time"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/google_sans_flex"
                        android:text="00:00:00"
                        android:textColor="@color/colorPrimary"
                        android:textSize="20sp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="25dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="left|center_vertical"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="19dp"
                        android:layout_height="19dp"
                        android:layout_marginTop="2dp"
                        app:srcCompat="@drawable/arrow_down"
                        android:layout_gravity="top"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:fontFamily="@font/google_sans_flex"
                            app:fontVariationSettings="'wght' 500" />

                        <TextView
                            android:id="@+id/bytes_in"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 B"
                            android:textColor="@color/black_light"
                            android:textSize="8sp"
                            android:fontFamily="@font/google_sans_flex"
                            app:fontVariationSettings="'wght' 600"/>

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/tunnel_spin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="V2Ray"
                        android:textColor="@color/black_light"
                        android:textSize="8sp"
                        android:fontFamily="@font/google_sans_flex"
                        app:fontVariationSettings="'wght' 500"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="right|center_vertical"
                    android:orientation="horizontal"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:fontFamily="@font/google_sans_flex"
                            app:fontVariationSettings="'wght' 500" />

                        <TextView
                            android:id="@+id/bytes_out"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="right"
                            android:text="0 B"
                            android:textColor="@color/black_light"
                            android:textSize="8sp"
                            android:fontFamily="@font/google_sans_flex"
                            app:fontVariationSettings="'wght' 600"/>

                    </LinearLayout>

                    <ImageView
                        android:layout_width="19dp"
                        android:layout_height="19dp"
                        android:layout_marginTop="2dp"
                        app:srcCompat="@drawable/arrow_up"
                        android:layout_gravity="top"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="3dp"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/server_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:onClick="onClick"
                        android:orientation="horizontal"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/server_spin_icon"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/app_main_logo" />

<!--                            <RelativeLayout-->
<!--                                android:layout_width="match_parent"-->
<!--                                android:layout_height="match_parent"-->
<!--                                android:background="@drawable/round_3d_circle">-->
<!--                            </RelativeLayout>-->
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingRight="2dp">

                            <TextView
                                android:id="@+id/server_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:singleLine="true"
                                android:text="Server"
                                android:textColor="@color/colorText"
                                android:textSize="11sp"
                                android:fontFamily="@font/google_sans_flex"
                                app:fontVariationSettings="'wght' 500"/>

                            <TextView
                                android:id="@+id/server_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:singleLine="true"
                                android:text="High Speed"
                                android:textColor="@color/colorPrimary"
                                android:textSize="10sp"
                                android:fontFamily="@font/google_sans_flex"
                                app:fontVariationSettings="'wght' 500"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/v2ray_ping"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~ ms"
                            android:textColor="@color/colorText"
                            android:textSize="11sp"
                            android:fontFamily="@font/google_sans_flex" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginLeft="2dp"
                    android:layout_marginRight="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="3dp"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/payload_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:onClick="onClick"
                        android:orientation="horizontal"
                        android:paddingStart="15dp"
                        android:paddingEnd="15dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="20dp">

                            <ImageView
                                android:id="@+id/payload_spin_icon"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/app_main_logo" />

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/round_3d_circle">
                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingRight="2dp">

                            <TextView
                                android:id="@+id/payload_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:singleLine="true"
                                android:text="Payload"
                                android:textColor="@color/colorText"
                                android:textSize="11sp"
                                android:fontFamily="@font/google_sans_flex"
                                app:fontVariationSettings="'wght' 500"/>

                            <TextView
                                android:id="@+id/payload_info"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:singleLine="true"
                                android:text="High Speed"
                                android:textColor="@color/colorPrimary"
                                android:textSize="10sp"
                                android:fontFamily="@font/google_sans_flex"
                                app:fontVariationSettings="'wght' 500"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/payload_tag_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/fix_tag_frame"
                            android:gravity="center"
                            android:paddingLeft="3.5dp"
                            android:paddingRight="3.5dp"
                            android:paddingTop="0.5dp"
                            android:paddingBottom="0.5dp"
                            android:text="V2ray/Xray"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            android:fontFamily="@font/google_sans_flex" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="2dp">

                <mtkdex.core.build.ssmen.view.RotateLoading
                    android:id="@+id/mRotateLoading"
                    android:layout_width="145dp"
                    android:layout_height="145dp"
                    android:layout_centerInParent="true"
                    app:loading_color="#14B455"
                    app:loading_visible="false"
                    app:loading_width="7dp" />

                <mtkdex.core.build.ssmen.view.CircleProgressBar
                    android:id="@+id/circle_progress"
                    android:layout_width="127dp"
                    android:layout_height="127dp"
                    android:layout_centerInParent="true"
                    app:progress="0"
                    app:progressBarThickness="10dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_ly"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_centerInParent="true"
                    app:cardBackgroundColor="#F5F5F5"
                    app:cardCornerRadius="53dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/btn_connect_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:src="@drawable/logout_button"
                            app:tint="@color/colorPrimary" />

                        <Button
                            android:id="@+id/btn_connect"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:onClick="onClick" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/usernameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:text=""
                    android:textSize="10sp"
                    android:fontFamily="@font/google_sans_flex"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Expiration Details"
                    android:textSize="12sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/colorTextSecondary"
                    android:fontFamily="@font/google_sans_flex"
                    app:fontVariationSettings="'wght' 550" />

                <TextView
                    android:id="@+id/ac_xp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expiry: -- ---, ---- | 0 Days"
                    android:textSize="11sp"
                    android:textColor="@color/colorPrimary"
                    android:layout_gravity="center"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/google_sans_flex"
                    app:fontVariationSettings="'wght' 500"/>
            </LinearLayout>

            <!-- Hidden Elements for MainActivity compatibility -->
            <TextView android:id="@+id/status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <TextView android:id="@+id/sname1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <TextView android:id="@+id/pname1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <LinearLayout android:id="@+id/sSpin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <LinearLayout android:id="@+id/pSpin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <TextView android:id="@+id/main_tl1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <ImageView android:id="@+id/show_password" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <ImageView android:id="@+id/ac_user_box_icon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <EditText android:id="@+id/x_username" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <EditText android:id="@+id/x_password" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
            <Spinner android:id="@+id/portSpin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <Spinner android:id="@+id/prxSpin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <com.google.android.material.bottomnavigation.BottomNavigationView android:id="@+id/navigationView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
            <TextView android:id="@+id/ipTextView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
            <TextView android:id="@+id/tv_test_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
            <LinearLayout android:id="@+id/layout_test" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" />
            <TextView android:id="@+id/sname3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
            <ImageView android:id="@+id/sicon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
            <TextView android:id="@+id/pname3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
